# =============================================================================
# Trade Sim App (Vite + React) — environment variables
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# WARNING: anything here ships to the browser — do not put real secrets here.
# =============================================================================

# Base URL of the trade-sim-backend API (no trailing slash).
# Local backend via docker-compose runs on port 5000.
VITE_API_BASE_URL=http://localhost:5000
